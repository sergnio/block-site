{
  "manifest_version": 3,
  "name": "Website Blocker",
  "version": "1.0",
  "description": "Extremely simple site blocker. No tracking, no subscription, just a site blocker for the people.",
  "permissions": ["declarativeNetRequest", "storage"],
  "icons": {
    "16": "icons/16.png",
    "48": "icons/48.png",
    "128": "icons/128.png"
  },
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_popup": "popup.html",
    "default_title": "Website Blocker",
    "default_icon": {
      "16": "icons/16.png",
      "48": "icons/48.png",
      "128": "icons/128.png"
    }
  }
}
